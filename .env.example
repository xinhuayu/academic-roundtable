# Provider credentials. Keep real values in .env.local only.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Momo: critical, methodological, and digest/synthesis participant.
MOMO_BASE_URL=https://api.openai.com/v1
MOMO_MODEL=gpt-5.6-luna
MOMO_API_STYLE=responses
MOMO_API_KEY_ENV=OPENAI_API_KEY
MOMO_REASONING_EFFORT=low
MOMO_FIRST_TOKEN_TIMEOUT_SECONDS=68
MOMO_STREAM_IDLE_TIMEOUT_SECONDS=68
MOMO_TOTAL_TIMEOUT_SECONDS=270

# Bobby: explanatory, mechanism-oriented case developer on Gemini.
# Google exposes an OpenAI-compatible chat-completions endpoint.
BOBBY_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
BOBBY_MODEL=gemini-3.1-flash-lite
BOBBY_API_STYLE=chat_completions
BOBBY_API_KEY_ENV=GEMINI_API_KEY
BOBBY_REASONING_EFFORT=low
BOBBY_CONNECT_TIMEOUT_SECONDS=10
BOBBY_FIRST_TOKEN_TIMEOUT_SECONDS=90
BOBBY_STREAM_IDLE_TIMEOUT_SECONDS=90
BOBBY_TOTAL_TIMEOUT_SECONDS=360

# To run Bobby on OpenAI instead, use these values:
# BOBBY_BASE_URL=https://api.openai.com/v1
# BOBBY_MODEL=gpt-5.6-terra
# BOBBY_API_STYLE=responses
# BOBBY_API_KEY_ENV=OPENAI_API_KEY

# Momo's OpenAI model produces source, topic, conversation, and final digests.
DIGEST_PROVIDER=momo
ROUND_DIGEST_INTERVAL=6
RECENT_ROUND_COUNT=5
# Legacy fallback plus participant-specific live allowances.
LIVE_MAX_OUTPUT_TOKENS=800
MOMO_LIVE_MAX_OUTPUT_TOKENS=800
BOBBY_LIVE_MAX_OUTPUT_TOKENS=1400
LIVE_TURN_TOKEN_BUDGET_MULTIPLIER=1.5
LIVE_TURN_TIMEOUT_BUDGET_MULTIPLIER=1.5
HOST_CHECKPOINT_INTERVAL=3
#
# Source-grounded discussion boosts:
# - single uploaded source document -> +50% token/time budget
# - two+ uploaded source documents -> up to +100% budget
# Install these packages in the backend runtime for robust PDF table/figure extraction:
#   pip install pymupdf pdfplumber
SOURCE_SINGLE_DOC_TOKEN_MULTIPLIER=1.5
SOURCE_MULTI_DOC_TOKEN_MULTIPLIER=2.0
SOURCE_SINGLE_DOC_TIMEOUT_MULTIPLIER=1.5
SOURCE_MULTI_DOC_TIMEOUT_MULTIPLIER=2.0
CONVERSATION_DIGEST_MAX_OUTPUT_TOKENS=4000
TOPIC_DIGEST_MAX_OUTPUT_TOKENS=6000
SOURCE_DIGEST_MAX_OUTPUT_TOKENS=8000
DIGEST_SECTION_TIMEOUT_SECONDS=300
DIGEST_JOB_TIMEOUT_SECONDS=900

# Local runtime
ROUNDTABLE_HOST=127.0.0.1
ROUNDTABLE_PORT=8765
ROUNDTABLE_DATA_DIR=./data
