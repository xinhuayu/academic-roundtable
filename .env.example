# Provider credentials. Keep real values in .env.local only.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Momo: critical, methodological, and digest/synthesis participant.
MOMO_BASE_URL=https://api.openai.com/v1
MOMO_MODEL=gpt-5.6-luna
MOMO_API_STYLE=responses
MOMO_API_KEY_ENV=OPENAI_API_KEY
MOMO_REASONING_EFFORT=low
MOMO_FIRST_TOKEN_TIMEOUT_SECONDS=68
MOMO_STREAM_IDLE_TIMEOUT_SECONDS=68
MOMO_TOTAL_TIMEOUT_SECONDS=270

# Bobby: explanatory, mechanism-oriented case developer on Gemini.
# Google exposes an OpenAI-compatible chat-completions endpoint.
BOBBY_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
BOBBY_MODEL=gemini-3.5-flash-lite
BOBBY_API_STYLE=chat_completions
BOBBY_API_KEY_ENV=GEMINI_API_KEY
BOBBY_REASONING_EFFORT=minimal
BOBBY_CONNECT_TIMEOUT_SECONDS=15
BOBBY_FIRST_TOKEN_TIMEOUT_SECONDS=60
BOBBY_STREAM_IDLE_TIMEOUT_SECONDS=60
BOBBY_TOTAL_TIMEOUT_SECONDS=360

# Optional per-session research profiles. Fast mode uses the provider blocks
# above. Research and verification mode switch to these models without changing
# the fast baseline. Verification uses high reasoning and is also selected for
# an explicit Sam request to check the original uploaded source.
RESEARCH_MOMO_MODEL=gpt-5.6-sol
RESEARCH_BOBBY_MODEL=gemini-3.6-flash
RESEARCH_MOMO_REASONING_EFFORT=medium
RESEARCH_BOBBY_REASONING_EFFORT=medium
VERIFICATION_MOMO_MODEL=gpt-5.6-sol
VERIFICATION_BOBBY_MODEL=gemini-pro-latest
VERIFICATION_MOMO_REASONING_EFFORT=high
VERIFICATION_BOBBY_REASONING_EFFORT=high
RESEARCH_LIVE_TOKEN_MULTIPLIER=2.75
RESEARCH_LIVE_TIMEOUT_MULTIPLIER=2.5
VERIFICATION_LIVE_TOKEN_MULTIPLIER=2.0
VERIFICATION_LIVE_TIMEOUT_MULTIPLIER=2.5
# Gemini reserves for hidden thinking plus the visible answer. These are API
# ceilings, not requested prose lengths; the conversation prompt remains concise.
GEMINI_FAST_MIN_OUTPUT_TOKENS=4096
GEMINI_RESEARCH_MIN_OUTPUT_TOKENS=12288
GEMINI_VERIFICATION_MIN_OUTPUT_TOKENS=32768
GEMINI_MAX_OUTPUT_TOKENS=65536
# Additional Gemini-only latency room layered over the profile multiplier.
GEMINI_RESEARCH_TIMEOUT_MULTIPLIER=2.0
GEMINI_VERIFICATION_TIMEOUT_MULTIPLIER=2.25
# One timeout-only retry; the retry alone receives a larger deadline.
LIVE_TIMEOUT_RETRY_ATTEMPTS=1
LIVE_TIMEOUT_RETRY_MULTIPLIER=1.5

# To run Bobby on OpenAI instead, use these values:
# BOBBY_BASE_URL=https://api.openai.com/v1
# BOBBY_MODEL=gpt-5.6-terra
# BOBBY_API_STYLE=responses
# BOBBY_API_KEY_ENV=OPENAI_API_KEY

# Optional native Claude alternative for Bobby (not enabled by default):
# To use instead of Gemini, replace the Bobby block above with:
# BOBBY_BASE_URL=https://api.anthropic.com/v1
# BOBBY_MODEL=claude-3-5-haiku-20241022
# BOBBY_API_STYLE=anthropic_messages
# BOBBY_API_KEY_ENV=ANTHROPIC_API_KEY

# Momo's OpenAI model produces source, topic, conversation, and final digests.
DIGEST_PROVIDER=momo
ROUND_DIGEST_INTERVAL=6
RECENT_ROUND_COUNT=5
# Legacy fallback plus participant-specific live allowances.
LIVE_MAX_OUTPUT_TOKENS=800
MOMO_LIVE_MAX_OUTPUT_TOKENS=800
BOBBY_LIVE_MAX_OUTPUT_TOKENS=1400
LIVE_TURN_TOKEN_BUDGET_MULTIPLIER=1.5
LIVE_TURN_TIMEOUT_BUDGET_MULTIPLIER=1.5
HOST_CHECKPOINT_INTERVAL=3
#
# Explicit original-source verification boosts:
# - ordinary rounds carry processed digests and use normal live limits
# - a Sam request to check the original document temporarily retrieves passages
# - one uploaded document -> +50% token/time budget for that verification segment
# - two+ uploaded documents -> up to +100% for that verification segment
# Install these packages in the backend runtime for robust PDF table/figure extraction:
#   pip install pymupdf pdfplumber
SOURCE_SINGLE_DOC_TOKEN_MULTIPLIER=1.5
SOURCE_MULTI_DOC_TOKEN_MULTIPLIER=2.0
SOURCE_SINGLE_DOC_TIMEOUT_MULTIPLIER=1.5
SOURCE_MULTI_DOC_TIMEOUT_MULTIPLIER=2.0
CONVERSATION_DIGEST_MAX_OUTPUT_TOKENS=4000
FINAL_SUMMARY_MAX_OUTPUT_TOKENS=6000
TOPIC_DIGEST_MAX_OUTPUT_TOKENS=6000
SOURCE_DIGEST_MAX_OUTPUT_TOKENS=8000
DIGEST_SECTION_TIMEOUT_SECONDS=300
DIGEST_JOB_TIMEOUT_SECONDS=900

# Sam voice input. Audio is held in memory, sent to the configured OpenAI
# transcription endpoint, returned as an editable draft, and never archived.
# There is no time cutoff: Sam stops recording manually. The provider's audio
# upload-size capacity remains the practical boundary for one recording.
VOICE_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_TRANSCRIPTION_API_KEY_ENV=OPENAI_API_KEY
VOICE_TRANSCRIPTION_TIMEOUT_SECONDS=480
VOICE_MAX_AUDIO_BYTES=26214400
# Longer voice/text comments receive more context room and response time while
# the visible AI contribution remains governed by the concise turn prompt.
LONG_SAM_INPUT_THRESHOLD_CHARS=3200
LONG_SAM_INPUT_TOKEN_MULTIPLIER=1.5
LONG_SAM_INPUT_TIMEOUT_MULTIPLIER=1.75

# Local runtime
ROUNDTABLE_HOST=127.0.0.1
ROUNDTABLE_PORT=8765
ROUNDTABLE_DATA_DIR=./data
